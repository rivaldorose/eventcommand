DATABASE_URL=postgresql://user:password@localhost:5432/eventcommand
PORT=3001

# Eventbrite OAuth (required for Marketplace)
EVENTBRITE_CLIENT_ID=your_eventbrite_client_id
EVENTBRITE_CLIENT_SECRET=your_eventbrite_client_secret
EVENTBRITE_REDIRECT_URI=https://yourdomain.com/api/auth/eventbrite/callback
EVENTBRITE_TOKEN=
EVENTBRITE_ORG_ID=

# Wix Events API
WIX_API_KEY=your_wix_api_key

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173
